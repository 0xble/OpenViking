#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

files=()
while IFS= read -r file; do
  files+=("$file")
done < <(
  git diff --cached --name-only --diff-filter=d -- \
    ':(glob)**/*.py' \
    ':(exclude)third_party/**'
)

if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

uv run ruff format --check "${files[@]}"
uv run ruff check "${files[@]}"
